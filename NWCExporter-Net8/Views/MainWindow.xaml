<Window x:Class="NWCExporter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NWC Exporter"
        Width="900"
        Height="820"
        MinWidth="800"
        MinHeight="700"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        ShowInTaskbar="false"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        FontSize="12">

    <!-- ══════════════════════════════════════════════════════════
         WINDOW RESOURCES
         ══════════════════════════════════════════════════════════ -->
    <Window.Resources>
        <ResourceDictionary>

            <!-- Merged Theme Dictionary (Light theme by default) -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NWCExporter;component/Themes/ThemeLight.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ─────────────────────────────────────────────────
                 BUTTON TEMPLATES & STYLES
                 ───────────────────────────────────────────────── -->

            <!-- Base control template for all custom buttons (rounded border + hover/disabled states) -->
            <ControlTemplate x:Key="DarkBtnTpl" TargetType="Button">
                <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <!-- Hover: swap background to hover brush -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                    </Trigger>
                    <!-- Disabled: fade out to 40% opacity -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Standard dark button style (uses DarkBtnTpl above) -->
            <Style x:Key="DarkBtn" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template" Value="{StaticResource DarkBtnTpl}"/>
            </Style>

            <!-- Accent (primary action) button — inherits DarkBtn, overrides colors to accent -->
            <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- ─────────────────────────────────────────────────
                 IMPLICIT CONTROL STYLES (apply to all instances)
                 ───────────────────────────────────────────────── -->

            <!-- TextBox: monospaced font, themed background/border -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- ComboBox: themed colors, minimum width for consistent sizing -->
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="5,3"/>
                <Setter Property="MinWidth" Value="120"/>
            </Style>

            <!-- CheckBox: secondary text color, vertically centered label -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- RadioButton: secondary text color, vertically centered label -->
            <Style TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- Label: dim color, small semi-bold — used as section headers above fields -->
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="0,0,0,3"/>
            </Style>

            <!-- ─────────────────────────────────────────────────
                 LIST STYLES
                 ───────────────────────────────────────────────── -->

            <!-- ListBox: panel background, themed border -->
            <Style TargetType="ListBox">
                <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            </Style>

            <!-- ListBoxItem: custom template with hover + selected highlights -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Selected: accent highlight background + accent foreground -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ListSelectionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                                <!-- Hover: subtle hover background -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!-- Button Styles                                                 -->
            <!-- ============================================================ -->

            <Style x:Key="AddButton" TargetType="Button">
                <Setter Property="Background"      Value="#1A7A3A"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Padding"         Value="14,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#22A052"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RemoveButton" TargetType="Button">
                <Setter Property="Background"      Value="#7A1A1A"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Padding"         Value="14,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#A02222"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


            <!-- ─────────────────────────────────────────────────
                 TAB STYLES
                 ───────────────────────────────────────────────── -->

            <!-- TabControl: transparent/borderless container -->
            <Style TargetType="TabControl">
                <Setter Property="Background" Value="{DynamicResource WindowBgBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <!-- TabItem: custom template — bottom border acts as active indicator -->
            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                <Setter Property="Padding" Value="18,9"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Active tab: window background + accent bottom border + primary text -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource WindowBgBrush}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ─────────────────────────────────────────────────
                 SETTINGS ROW STYLE
                 (used in Navisworks Settings tab)
                 ───────────────────────────────────────────────── -->

            <!-- SettingRow: full-width bordered row with hover highlight -->
            <Style x:Key="SettingRow" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PanelBgBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="16,6"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════
         ROOT LAYOUT
         Row 0 → Tab content (fills available space)
         Row 1 → Footer action bar (auto height)
         ══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Main Content Area ── -->
        <Grid Grid.Row="0">
            <TabControl>

                <!-- ════════════════════════════════════════════
                     TAB 1 — SOURCE & OUTPUT
                     ════════════════════════════════════════════ -->
                <TabItem Header="Source &amp; Output">
                    <Grid Margin="16,14,16,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Source path field       -->
                            <RowDefinition Height="Auto"/>
                            <!-- Output path field       -->
                            <RowDefinition Height="Auto"/>
                            <!-- File list toolbar       -->
                            <RowDefinition Height="180"/>
                            <!-- Selected files list     -->
                            <RowDefinition Height="Auto"/>
                            <!-- Include subfolders      -->
                            <RowDefinition Height="Auto"/>
                            <!-- Export scope header     -->
                            <RowDefinition Height="Auto"/>
                            <!-- Scope radio buttons     -->
                            <RowDefinition Height="*"/>
                            <!-- 3D views list (expands) -->
                        </Grid.RowDefinitions>

                        <!-- ── Source Path ── -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Content="SOURCE PATH"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,6,0"/>
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Style="{StaticResource DarkBtn}"
                                        Command="{Binding BrowseSourceCommand}"/>
                            </Grid>
                        </Grid>

                        <!-- ── Output Path ── -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Content="OUTPUT PATH"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,6,0"/>
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Style="{StaticResource DarkBtn}"
                                        Command="{Binding BrowseOutputCommand}"/>
                            </Grid>
                        </Grid>

                        <!-- ── Selected Files Toolbar (label + separator + Add/Remove/Clear) ── -->
                        <Grid Grid.Row="2" Margin="0,4,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- "SELECTED FILES" label -->
                                <ColumnDefinition Width="*"/>
                                <!-- Separator              -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- + Add button           -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Remove button          -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Clear All button       -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="SELECTED FILES"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Center"/>

                            <Separator Grid.Column="1"
                                       Background="{DynamicResource BorderBrushTheme}"
                                       Height="1"
                                       Margin="8,0"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="2"
                                    Style="{StaticResource AddButton}"
                                    Command="{Binding AddFileCommand}"
                                    Padding="10,5"
                                    Margin="0,0,4,0"
                                    Content="+ Add"/>

                            <Button Grid.Column="3"
                                    Style="{StaticResource RemoveButton}"
                                    Command="{Binding RemoveFileCommand}"
                                    Padding="10,5"
                                    Margin="0,0,4,0"
                                    Content="Remove"/>

                            <Button Grid.Column="4"
                                    Content="Clear All"
                                    Style="{StaticResource DarkBtn}"
                                    Command="{Binding ClearAllFilesCommand}"
                                    Padding="8,3"
                                    FontSize="11"/>
                        </Grid>

                        <!-- ── Selected Files ListBox (checkbox + icon + filename per item) ── -->
                        <ListBox Grid.Row="3"
                                 ItemsSource="{Binding SelectedFiles}"
                                 SelectedItem="{Binding SelectedFileItem, Mode=TwoWay}"
                                 Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,0,8,0"/>
                                        <TextBlock Text="🗂 " FontSize="12"/>
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- ── Include Sub Folders option with info badge ── -->
                        <Border Grid.Row="4"
                                Background="{DynamicResource PanelBgBrush}"
                                BorderBrush="{DynamicResource BorderBrushTheme}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Margin="0,0,0,12"
                                Padding="10,7">
                            <CheckBox IsChecked="{Binding IncludeSubFolders}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Include Sub Folders"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <!-- Info badge: explains what the option does -->
                                    <Border Background="{DynamicResource ListSelectionBrush}"
                                            CornerRadius="8"
                                            Margin="8,0,0,0"
                                            Padding="6,1">
                                        <TextBlock Text="Scans all sub-folders for .rvt files"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                            </CheckBox>
                        </Border>

                        <!-- ── Export Scope section header ── -->
                        <Grid Grid.Row="5" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="EXPORT SCOPE"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Center"/>

                            <Separator Grid.Column="1"
                                       Background="{DynamicResource BorderBrushTheme}"
                                       Height="1"
                                       Margin="8,0"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- ── Export Scope: Whole Model vs Custom Views radio buttons ── -->
                        <StackPanel Grid.Row="6"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <RadioButton Content="Whole Model"
                                         IsChecked="{Binding IsWholeModel}"
                                         Margin="0,0,20,0"/>
                            <RadioButton Content="Custom Views"
                                         IsChecked="{Binding IsCustomViews}"/>
                        </StackPanel>

                        <!-- ── 3D Views List (visible only when Custom Views is selected) ── -->
                        <Grid Grid.Row="7"
                              Visibility="{Binding ViewsListVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="3D VIEWS IN PROJECT"/>
                            <!-- Each view item: checkbox + accent diamond icon + view name -->
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding AvailableViews}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Margin="0,0,8,0"/>
                                            <TextBlock Text="◈ " Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                    </Grid>
                </TabItem>

                <!-- ════════════════════════════════════════════
                     TAB 2 — NAVISWORKS SETTINGS
                     Scrollable list of export options + Defaults button
                     ════════════════════════════════════════════ -->
                <TabItem Header="Navisworks Settings">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <!-- Scrollable settings rows -->
                            <RowDefinition Height="Auto"/>
                            <!-- Defaults button footer   -->
                        </Grid.RowDefinitions>

                        <!-- ── Scrollable Settings Rows ── -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Boolean toggles: each wrapped in a SettingRow border -->
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertConstructionParts}"
                                              Content="Convert construction parts"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertElementIds}"
                                              Content="Convert element Ids"/>
                                </Border>

                                <!-- Dropdown setting: Convert element parameters -->
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <TextBlock Text="Convert element parameters"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox DockPanel.Dock="Right"
                                                  HorizontalAlignment="Right"
                                                  ItemsSource="{Binding SettingsVM.ParameterOptions}"
                                                  SelectedItem="{Binding SettingsVM.ConvertElementParameters}"/>
                                    </DockPanel>
                                </Border>

                                <!-- Boolean toggles continued -->
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertElementProperties}"
                                              Content="Convert element properties"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertLights}"
                                              Content="Convert lights"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertLinkedCadFormats}"
                                              Content="Convert linked CAD formats"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertLinkedFiles}"
                                              Content="Convert linked files"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertRoomAsAttribute}"
                                              Content="Convert room as attribute"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ConvertUrls}"
                                              Content="Convert URLs"/>
                                </Border>

                                <!-- Dropdown setting: Coordinates -->
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <TextBlock Text="Coordinates"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox DockPanel.Dock="Right"
                                                  HorizontalAlignment="Right"
                                                  ItemsSource="{Binding SettingsVM.CoordinateOptions}"
                                                  SelectedItem="{Binding SettingsVM.Coordinates}"/>
                                    </DockPanel>
                                </Border>

                                <!-- Boolean toggles continued -->
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.DivideFileIntoLevels}"
                                              Content="Divide File into Levels"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.EmbedTextures}"
                                              Content="Embed Textures"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.ExportRoomGeometry}"
                                              Content="Export room geometry"/>
                                </Border>

                                <!-- Numeric input: Faceting Factor (overrides implicit TextBox style for alignment) -->
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <TextBlock Text="Faceting Factor"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox DockPanel.Dock="Right"
                                                 HorizontalAlignment="Right"
                                                 Width="100"
                                                 FontFamily="Segoe UI"
                                                 Background="{DynamicResource InputBgBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderBrush="{DynamicResource BorderBrushTheme}"
                                                 BorderThickness="1"
                                                 Padding="5,3"
                                                 Text="{Binding SettingsVM.FacetingFactor, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DockPanel>
                                </Border>

                                <!-- Boolean toggles continued -->
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.SeparateCustomProperties}"
                                              Content="Separate Custom properties"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.StrictSectioning}"
                                              Content="Strict Sectioning"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.TryFindMissingMaterials}"
                                              Content="Try and find missing materials"/>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <CheckBox IsChecked="{Binding SettingsVM.TypePropertiesOnElements}"
                                              Content="Type properties on Elements"/>
                                </Border>
                                
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── Defaults Button Footer ── -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource WindowBgBrush}"
                                Padding="16,8">
                            <Button Content="Defaults"
                                    Style="{StaticResource DarkBtn}"
                                    HorizontalAlignment="Right"
                                    Padding="16,5"
                                    Command="{Binding ResetDefaultsCommand}"/>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Toggle Theme button — floats top-right over the TabControl -->
            <Button Content="Toggle Theme"
                    Style="{StaticResource DarkBtn}"
                    Padding="10,4"
                    FontSize="11"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,16,0"
                    Click="ToggleTheme_Click"/>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             Row 1 — FOOTER ACTION BAR
             Left:  status message + progress bar
             Right: Folder-per-project checkbox + Export + Close
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderBrushTheme}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Status / progress area -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Action buttons area    -->
                </Grid.ColumnDefinitions>

                <!-- ── Left: Status message + Progress bar ── -->
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center">

                    <!-- Status indicator: green dot + status text (shown when StatusVisibility is Visible) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding StatusVisibility}">
                        <Ellipse Width="7" Height="7"
                                 Fill="{DynamicResource SuccessBrush}"
                                 Margin="0,0,7,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="11.5"/>
                    </StackPanel>

                    <!-- Progress section: text label + progress bar (shown during export) -->
                    <StackPanel Margin="0,6,0,0"
                                Visibility="{Binding ProgressVisibility}">
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>

                        <ProgressBar Minimum="0"
                                     Maximum="{Binding ProgressMaximum}"
                                     Value="{Binding ProgressValue}"
                                     Height="10"
                                     Width="320"/>
                    </StackPanel>
                </StackPanel>

                <!-- ── Right: Folder per project option + Export + Close ── -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Option: create a separate output folder per Revit project -->
                    <CheckBox IsChecked="{Binding SettingsVM.CreateFolderPerProject}"
                              Content="Folder per project"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"/>

                    <!-- Primary action: triggers the NWC export process -->
                    <Button Content="Export"
                            Style="{StaticResource AccentBtn}"
                            Command="{Binding ExportCommand}"
                            Width="80"
                            Margin="0,0,8,0"/>

                    <!-- Close button: passes the Window as CommandParameter for clean shutdown -->
                    <Button Content="Close"
                            Style="{StaticResource DarkBtn}"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="65"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>